---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mauro Risso | Product Software Engineer">
  <!-- Tab Navigation -->
  <nav class="mb-8">
    <ul class="flex gap-8">
      <li>
        <button
          data-tab="present"
          class="tab-button text-zinc-100 hover:underline underline-offset-4 transition-all"
        >
          Present
        </button>
      </li>
      <li>
        <button
          data-tab="past"
          class="tab-button text-zinc-400 hover:text-zinc-100 hover:underline underline-offset-4 transition-all"
        >
          Past
        </button>
      </li>
    </ul>
  </nav>

  <!-- Present Tab Content -->
  <section id="present-tab" class="tab-panel min-h-[320px]">
    <div class="flex flex-col gap-8">
      <!-- Description -->
      <div class="flex flex-col gap-4">
        <p class="text-zinc-100">
          I am a product software engineer, a son, a brother, a friend, or
          probably just a stranger.
        </p>
        <p class="text-zinc-100">
          Curious and interested in tech, design, SaaS, branding, fashion,
          music, art, and more.
        </p>
      </div>

      <!-- Current Work -->
      <div class="flex flex-col gap-4">
        <div class="flex gap-12">
          <span class="text-zinc-400 min-w-[120px]">Since 2026</span>
          <div>
            <span class="text-zinc-100">Product engineer at </span>
            <a
              href="https://handly.de"
              class="text-zinc-100 hover:underline underline-offset-4 transition-all"
            >
              handly.de
            </a>
          </div>
        </div>

        <div class="flex gap-12">
          <span class="text-zinc-400 min-w-[120px]">Since 2018</span>
          <span class="text-zinc-100">Living in Berlin</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Past Tab Content -->
  <section id="past-tab" class="tab-panel min-h-[320px] hidden">
    <div class="flex flex-col gap-6">
      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2026 — Now</span>
        <div>
          <span class="text-zinc-100">Product Engineer at </span>
          <a
            href="https://handly.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            handly.de
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2025 — 2026</span>
        <div>
          <span class="text-zinc-100">Founding Product Engineer at </span>
          <a
            href="https://usekinetic.com"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Kinetic
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2024 — 2025</span>
        <div>
          <span class="text-zinc-100">Full Stack Engineer at </span>
          <a
            href="https://www.otto.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            OTTO
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2023 — 2024</span>
        <div>
          <span class="text-zinc-100">Frontend Developer at </span>
          <a
            href="https://www.nosto.com"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Nosto
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2021 — 2022</span>
        <div>
          <span class="text-zinc-100">Working Student at </span>
          <a
            href="https://www.cariad.com"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            CARIAD
          </a>
          <span class="text-zinc-100"> & </span>
          <a
            href="https://www.apploft.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            apploft
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2020 — 2024</span>
        <div>
          <span class="text-zinc-100">Computer Science at </span>
          <a
            href="https://www.htw-berlin.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            HTW Berlin
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2019 — 2020</span>
        <div>
          <span class="text-zinc-100">Frontend Developer at </span>
          <a
            href="https://www.crunchbase.com/organization/chipstv"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            ChipsTV
          </a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function setupTabs() {
      const tabButtons = document.querySelectorAll(".tab-button");
      const tabContents = document.querySelectorAll(".tab-panel");

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const tabName = button.getAttribute("data-tab");

          // Update button states
          tabButtons.forEach((btn) => {
            if (btn === button) {
              btn.classList.remove("text-zinc-400");
              btn.classList.add("text-zinc-100");
            } else {
              btn.classList.remove("text-zinc-100");
              btn.classList.add("text-zinc-400");
            }
          });

          // Update content visibility
          tabContents.forEach((content) => {
            if (content.id === `${tabName}-tab`) {
              content.classList.remove("hidden");
            } else {
              content.classList.add("hidden");
            }
          });
        });
      });
    }

    // Run immediately
    setupTabs();

    // Run on view transitions
    document.addEventListener("astro:after-swap", setupTabs);
  </script>
</Layout>
