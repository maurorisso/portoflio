---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mauro Risso | Product Software Engineer">
  <!-- Tab Navigation -->
  <nav class="mb-16">
    <ul class="flex gap-8">
      <li>
        <button
          data-tab="present"
          class="tab-button text-zinc-100 hover:underline underline-offset-4 transition-all"
        >
          Present
        </button>
      </li>
      <li>
        <button
          data-tab="past"
          class="tab-button text-zinc-400 hover:text-zinc-100 hover:underline underline-offset-4 transition-all"
        >
          Past
        </button>
      </li>
    </ul>
  </nav>

  <!-- Present Tab Content -->
  <section id="present-tab" class="tab-content">
    <div class="flex flex-col gap-16">
      <!-- Description -->
      <div class="flex flex-col gap-4">
        <p class="text-zinc-100">
          Product engineer based in Berlin
        </p>
        <p class="text-zinc-100">
          Curious, interested in design and systems
        </p>
      </div>

      <!-- Current Work -->
      <div class="flex flex-col gap-6">
        <div class="flex gap-12">
          <span class="text-zinc-400 min-w-[120px]">Since 2026</span>
          <div>
            <span class="text-zinc-100">Product engineer at </span>
            <a
              href="https://handly.de"
              class="text-zinc-100 hover:underline underline-offset-4 transition-all"
            >
              handly.de
            </a>
          </div>
        </div>

        <div class="flex gap-12">
          <span class="text-zinc-400 min-w-[120px]">Since 2018</span>
          <span class="text-zinc-100">Living in Berlin</span>
        </div>
      </div>

      <!-- Get in touch -->
      <div class="flex flex-col gap-6">
        <h2 class="text-zinc-100">Get in touch</h2>
        <div class="flex gap-6">
          <a
            href="https://github.com/maurorisso"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            GitHub↗
          </a>
          <a
            href="https://linkedin.com/in/maurorisso"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            LinkedIn↗
          </a>
          <a
            href="#"
            onclick="event.preventDefault(); this.textContent = 'me[at]maurorisso.com'"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Email↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Past Tab Content -->
  <section id="past-tab" class="tab-content hidden">
    <div class="flex flex-col gap-6">
      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2026 — Now</span>
        <div>
          <span class="text-zinc-100">Product engineer at </span>
          <a
            href="https://handly.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            handly.de
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2023 — 2025</span>
        <div>
          <span class="text-zinc-100">Full-Stack Developer at </span>
          <a
            href="https://www.otto.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Otto.de
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2021 — 2023</span>
        <div>
          <span class="text-zinc-100">Frontend Developer at </span>
          <a
            href="https://www.nosto.com"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Nosto
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2019 — 2021</span>
        <div>
          <span class="text-zinc-100">Working Student at </span>
          <a
            href="https://www.cariad.com"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            CARIAD
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2018 — 2019</span>
        <div>
          <span class="text-zinc-100">Working Student at </span>
          <a
            href="https://www.apploft.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            Apploft
          </a>
        </div>
      </div>

      <div class="flex gap-12">
        <span class="text-zinc-400 min-w-[120px]">2016 — 2022</span>
        <div>
          <span class="text-zinc-100">Bachelor of Science at </span>
          <a
            href="https://www.htw-berlin.de"
            class="text-zinc-100 hover:underline underline-offset-4 transition-all"
          >
            HTW Berlin
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    function setupTabs() {
      const tabButtons = document.querySelectorAll('.tab-button');
      const tabContents = document.querySelectorAll('.tab-content');

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const tabName = button.getAttribute('data-tab');

          // Update button states
          tabButtons.forEach(btn => {
            if (btn === button) {
              btn.classList.remove('text-zinc-400');
              btn.classList.add('text-zinc-100');
            } else {
              btn.classList.remove('text-zinc-100');
              btn.classList.add('text-zinc-400');
            }
          });

          // Update content visibility
          tabContents.forEach(content => {
            if (content.id === `${tabName}-tab`) {
              content.classList.remove('hidden');
            } else {
              content.classList.add('hidden');
            }
          });
        });
      });
    }

    // Run on initial load
    document.addEventListener('DOMContentLoaded', setupTabs);

    // Run on view transitions
    document.addEventListener('astro:after-swap', setupTabs);
  </script>
</Layout>
