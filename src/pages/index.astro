---
import Layout from "../layouts/Layout.astro";

const work = [
  { when: "2026 — Now", role: "Product Engineer", at: "handly.de", href: "https://handly.de" },
  { when: "2025 — 2026", role: "Founding Product Engineer", at: "Kinetic", href: "https://usekinetic.com" },
  { when: "2024 — 2025", role: "Full-Stack Engineer", at: "OTTO", href: "https://www.otto.de" },
  { when: "2023 — 2024", role: "Frontend Developer", at: "Nosto", href: "https://www.nosto.com" },
  { when: "2021 — 2022", role: "Working Student", at: "CARIAD & apploft", href: "https://www.cariad.com" },
  { when: "2020 — 2024", role: "Computer Science", at: "HTW Berlin", href: "https://www.htw-berlin.de" },
  { when: "2019 — 2020", role: "Frontend Developer", at: "ChipsTV", href: "https://www.crunchbase.com/organization/chipstv" },
];

const interests =["tech", "design", "SaaS", "branding", "fashion", "music", "art", "type", "startups", "Berlin"];
---

<Layout title="Mauro Risso | Product Software Engineer">
  <!-- Intro -->
  <section class="reveal flex flex-col gap-4">
    <p class="text-zinc-100 leading-relaxed">
      I am a product software engineer, a son, a brother, a friend, or probably
      just a stranger.
    </p>
    <p class="text-zinc-400 leading-relaxed">
      Curious and interested in tech, design, SaaS, branding, fashion, music,
      art, and more.
    </p>
  </section>

  <!-- Now -->
  <section class="mt-14 flex flex-col gap-3">
    <h2 class="reveal scramble text-zinc-500 lowercase tracking-widest text-xs">
      now
    </h2>
    <div class="reveal flex gap-12" style="--i: 1">
      <span class="text-zinc-400 min-w-[120px]">Building</span>
      <div>
        <span class="text-zinc-100">Product engineer at </span>
        <a href="https://handly.de" class="link swapper">handly.de</a>
      </div>
    </div>
    <div class="reveal flex gap-12" style="--i: 2">
      <span class="text-zinc-400 min-w-[120px]">Based in</span>
      <div>
        <span class="text-zinc-100">Berlin</span>
        <span class="text-zinc-500"> · <span id="clock">--:--:--</span></span>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section class="mt-14 flex flex-col gap-3">
    <h2 class="reveal scramble text-zinc-500 lowercase tracking-widest text-xs">
      work
    </h2>
    {
      work.map((w, i) => (
        <div class="row reveal flex gap-12" style={`--i: ${i + 1}`}>
          <span class="text-zinc-400 min-w-[120px]">{w.when}</span>
          <div>
            <span class="text-zinc-100">{w.role} at </span>
            <a href={w.href} target="_blank" rel="noopener" class="link swapper">
              {w.at}
            </a>
          </div>
        </div>
      ))
    }
  </section>

  <!-- Interests marquee -->
  <section class="mt-14 flex flex-col gap-3">
    <h2 class="reveal scramble text-zinc-500 lowercase tracking-widest text-xs">
      into
    </h2>
    <div class="reveal marquee text-zinc-500" style="--i: 1">
      <div class="marquee__track">
        {[0, 1].map(() => (
          <span class="marquee__group">
            {interests.map((t) => (
              <span class="marquee__item">{t}</span>
            ))}
          </span>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.6s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
    transition-delay: calc(var(--i, 0) * 0.06s);
  }
  .reveal.in {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* links */
  .link {
    color: #fbf6ef;
    transition: color 0.2s ease;
  }
  .link:hover {
    color: #520B18;
  }
  .link::after {
    content: "↗";
    margin-left: 0.15em;
    color: #520B18;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .link:hover::after {
    opacity: 1;
  }

  /* dim sibling rows while hovering one */
  section:has(.row:hover) .row:not(:hover) {
    opacity: 0.35;
  }
  .row {
    transition:
      opacity 0.25s ease,
      transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  /* marquee */
  .marquee {
    overflow: hidden;
    white-space: nowrap;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 12%,
      #000 88%,
      transparent
    );
    mask-image: linear-gradient(
      90deg,
      transparent,
      #000 12%,
      #000 88%,
      transparent
    );
  }
  .marquee__track {
    display: inline-flex;
    width: max-content;
    animation: scroll 22s linear infinite;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  .marquee__item {
    margin: 0 1.25rem;
  }
  .marquee__item::before {
    content: "✦ ";
    color: #520B18;
  }
  @keyframes scroll {
    to {
      transform: translateX(-50%);
    }
  }
</style>

<script is:inline>
  const FONTS = Array.from(
    { length: 28 },
    (_, i) => "pf" + String(i).padStart(2, "0"),
  );
  const rndFont = () => FONTS[Math.floor(Math.random() * FONTS.length)];

  function berlinClock() {
    const el = document.getElementById("clock");
    if (!el) return;
    const fmt = new Intl.DateTimeFormat("en-GB", {
      timeZone: "Europe/Berlin",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
    const tick = () => (el.textContent = fmt.format(new Date()));
    tick();
    clearInterval(window.__clock);
    window.__clock = setInterval(tick, 1000);
  }

  // Name swaps font as the cursor moves the page (Almabrava-style).
  function nameFontSwap() {
    const name = document.getElementById("name");
    if (!name || name.dataset.swap) return;
    name.dataset.swap = "1";
    let current = "";
    let last = 0;
    const swap = () => {
      const now = performance.now();
      if (now - last < 80) return;
      last = now;
      let next = current;
      while (next === current) next = rndFont();
      current = next;
      name.style.fontFamily = "'" + next + "', sans-serif";
    };
    window.addEventListener("mousemove", swap);
    window.addEventListener("touchmove", swap, { passive: true });
  }

  // Hovering any company/project name flips it into a random display face.
  function hoverSwap() {
    document.querySelectorAll(".swapper").forEach((el) => {
      if (el.dataset.hs) return;
      el.dataset.hs = "1";
      el.addEventListener("mouseenter", () => {
        el.style.fontFamily = "'" + rndFont() + "', sans-serif";
      });
      el.addEventListener("mouseleave", () => {
        el.style.fontFamily = "";
      });
    });
  }

  // Thin green scroll-progress bar.
  function scrollProgress() {
    const bar = document.getElementById("progress");
    if (!bar) return;
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      bar.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + "%";
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Reveal on scroll; scramble-decode section labels as they enter.
  function reveals() {
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ#%&@/*";
    const scramble = (el) => {
      const real = el.dataset.real || el.textContent;
      el.dataset.real = real;
      let frame = 0;
      const run = () => {
        el.textContent = real
          .split("")
          .map((c, i) =>
            c === " "
              ? " "
              : i < frame / 2
                ? real[i]
                : chars[Math.floor(Math.random() * chars.length)],
          )
          .join("");
        frame++;
        if (frame / 2 < real.length) requestAnimationFrame(run);
        else el.textContent = real;
      };
      run();
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          e.target.classList.add("in");
          if (e.target.classList.contains("scramble")) scramble(e.target);
          io.unobserve(e.target);
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -8% 0px" },
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
  }

  function setup() {
    berlinClock();
    nameFontSwap();
    hoverSwap();
    scrollProgress();
    reveals();
  }
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
