---
import Layout from "../layouts/Layout.astro";

const work = [
  { when: "2026 — Now", role: "Product Engineer", at: "handly.de", href: "https://handly.de" },
  { when: "2025 — 2026", role: "Founding Product Engineer", at: "Kinetic", href: "https://usekinetic.com" },
  { when: "2024 — 2025", role: "Full-Stack Engineer", at: "OTTO", href: "https://www.otto.de" },
  { when: "2023 — 2024", role: "Frontend Developer", at: "Nosto", href: "https://www.nosto.com" },
  { when: "2021 — 2022", role: "Working Student", at: "CARIAD & apploft", href: "https://www.cariad.com" },
  { when: "2020 — 2024", role: "Computer Science", at: "HTW Berlin", href: "https://www.htw-berlin.de" },
  { when: "2019 — 2020", role: "Frontend Developer", at: "ChipsTV", href: "https://www.crunchbase.com/organization/chipstv" },
];
---

<Layout title="Mauro Risso | Product Software Engineer">
  <!-- Intro -->
  <section class="reveal flex flex-col gap-4" style="--i: 0">
    <p class="text-zinc-100 leading-relaxed">
      I am a product software engineer, a son, a brother, a friend, or probably
      just a stranger.
    </p>
    <p class="text-zinc-400 leading-relaxed">
      Curious and interested in tech, design, SaaS, branding, fashion, music,
      art, and more.
    </p>
  </section>

  <!-- Now -->
  <section class="reveal mt-12 flex flex-col gap-3" style="--i: 1">
    <h2 class="text-zinc-500 lowercase tracking-widest text-xs">now</h2>
    <div class="flex gap-12">
      <span class="text-zinc-400 min-w-[120px]">Building</span>
      <div>
        <span class="text-zinc-100">Product engineer at </span>
        <a href="https://handly.de" class="link">handly.de</a>
      </div>
    </div>
    <div class="flex gap-12">
      <span class="text-zinc-400 min-w-[120px]">Based in</span>
      <div>
        <span class="text-zinc-100">Berlin</span>
        <span class="text-zinc-500"> · <span id="clock">--:--:--</span></span>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section class="reveal mt-12 flex flex-col gap-3" style="--i: 2">
    <h2 class="text-zinc-500 lowercase tracking-widest text-xs">work</h2>
    {
      work.map((w) => (
        <div class="row flex gap-12">
          <span class="text-zinc-400 min-w-[120px]">{w.when}</span>
          <div>
            <span class="text-zinc-100">{w.role} at </span>
            <a href={w.href} target="_blank" rel="noopener" class="link">
              {w.at}
            </a>
          </div>
        </div>
      ))
    }
  </section>
</Layout>

<style>
  .link {
    color: #fbf6ef;
    transition: color 0.2s ease;
  }
  .link:hover {
    color: #96cd79;
  }
  .link::after {
    content: "↗";
    margin-left: 0.15em;
    color: #96cd79;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .link:hover::after {
    opacity: 1;
  }

  .row {
    transition: opacity 0.2s ease;
  }
  /* dim the other rows while hovering one */
  section:has(.row:hover) .row:not(:hover) {
    opacity: 0.4;
  }

  .reveal {
    opacity: 0;
    transform: translateY(8px);
    animation: rise 0.5s ease forwards;
    animation-delay: calc(var(--i) * 0.12s + 0.05s);
  }
  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script is:inline>
  function berlinClock() {
    const el = document.getElementById("clock");
    if (!el) return;
    const fmt = new Intl.DateTimeFormat("en-GB", {
      timeZone: "Europe/Berlin",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
    const tick = () => {
      el.textContent = fmt.format(new Date());
    };
    tick();
    window.clearInterval(window.__clock);
    window.__clock = window.setInterval(tick, 1000);
  }

  // Almabrava-style: swap the name's font as the cursor moves the page.
  function nameFontSwap() {
    const name = document.getElementById("name");
    if (!name || name.dataset.swap) return;
    name.dataset.swap = "1";

    const FONTS = Array.from({ length: 28 }, (_, i) =>
      "pf" + String(i).padStart(2, "0"),
    );
    let current = "";
    let last = 0;

    const swap = () => {
      const now = performance.now();
      if (now - last < 80) return; // throttle so each face is legible
      last = now;
      let next = current;
      while (next === current) {
        next = FONTS[Math.floor(Math.random() * FONTS.length)];
      }
      current = next;
      name.style.fontFamily = "'" + next + "', sans-serif";
    };

    window.addEventListener("mousemove", swap);
    window.addEventListener("touchmove", swap, { passive: true });
  }

  function setup() {
    berlinClock();
    nameFontSwap();
  }
  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
